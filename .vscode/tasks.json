{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "compile",
      "type": "shell",
      "command": "pnpm",
      "args": ["compile"],
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": "$tsc",
      "presentation": { "reveal": "silent", "clear": true }
    },
    {
      "label": "watch",
      "type": "shell",
      "command": "pnpm",
      "args": ["watch"],
      "group": "build",
      "isBackground": true,
      "problemMatcher": "$tsc-watch",
      "presentation": { "reveal": "silent" }
    }
  ]
}
